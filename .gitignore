# 时间：2026-03-21T08:16:00+08:00
# [AILANG: human.config → ailang.config]
# ============================================================

# [AILANG: python.cache.exclude]
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# [AILANG: user.data.privacy]
data/*.json
data/*.db
data/*.sqlite
diaries_raw/

# [AILANG: internalized.data.privacy]
internalized_wisdom.json
internalization_report.md
internalize_diaries.py

# [AILANG: temp.files.exclude]
*.tmp
*.log
*.ab

# [AILANG: os.metadata.exclude]
.DS_Store
Thumbs.db

# [AILANG.META.END]
